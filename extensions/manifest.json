{
    "manifest_version": 3,
    "name": "Jobalytics Clone",
    "version": "1.1",
    "permissions": [
        "tabs",
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "http://localhost:3001/*",
        "http://localhost:5001/*",
        "http://localhost:5005/*",
        "https://huggingface.co/*",
        "https://cdn.jsdelivr.net/*"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.linkedin.com/*",
                "*://*.indeed.com/*"
            ],
            "js": [
                "content.js"
            ],
            "all_frames": false
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "styles.css"
            ],
            "matches": [
                "*://*.linkedin.com/*",
                "*://*.indeed.com/*"
            ]
        }
    ]
}